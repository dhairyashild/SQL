# SUM() - WITH SAMPLE TABLE & OUTPUT


SAMPLE TABLE: Student
+----+------+-------+----------+
| ID | Name | Marks | Dept     |
+----+------+-------+----------+
| 1  | A    | 90    | Science  |
| 2  | B    | 40    | Science  |
| 3  | C    | 70    | Commerce |
| 4  | D    | 60    | Commerce |
| 5  | E    | 70    | Arts     |
| 6  | F    | NULL  | Arts     |
+----+------+-------+----------+

================================================================

SELECT SUM(Marks) FROM Student;        -- Sum all non-NULL marks → O/P: 330

SELECT SUM(DISTINCT Marks) FROM Student; -- Sum unique non-NULL marks → O/P: 260

SELECT SUM(Marks) FROM Student WHERE Dept = 'Science'; -- Sum filtered by dept → O/P: 130

SELECT Dept, SUM(Marks) FROM Student GROUP BY Dept; -- Sum per group → O/P: Science=130, Commerce=130, Arts=70

SELECT SUM(Marks) AS total_marks FROM Student; -- Renamed output column → O/P: total_marks = 330

SELECT SUM(Marks) / COUNT(*) as avg_marks FROM Student; -- Average including NULLs → O/P: 55

SELECT Dept, SUM(Marks), COUNT(*) FROM Student GROUP BY Dept; -- Sum + count per group → O/P: Science=130,2 | Commerce=130,2 | Arts=70,2


RULE: SUM(col) = adds all non-NULLs | SUM(DISTINCT) = adds unique values | NULLs ignored in SUM

