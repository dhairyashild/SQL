COUNT(): Count function returns the number of rows that matches specified criterion

SELECT COUNT(column_name)
FROM table_name
WHERE condition;


================================================================
SAMPLE TABLE: employees
+----+-------+--------+--------+
| id | name  | dept   | salary |
+----+-------+--------+--------+
| 1  | Amit  | IT     | 50000  |
| 2  | NULL  | IT     | 60000  |
| 3  | Neha  | HR     | NULL   |
| 4  | Raj   | HR     | 45000  |
| 5  | NULL  | NULL   | NULL   |
+----+-------+--------+--------+


SELECT COUNT(*) FROM employees;        -- All rows fastest: 5

SELECT COUNT(name) FROM employees;     -- Non-NULL IN THAT COLUMN: 5-2 =3        MINUS 2 BECAUSE 2  NULL IN COLUMN NAME

SELECT COUNT(DISTINCT dept) FROM employees; -- Unique non-NULL IN THAT COLUMN → O/P: 2

SELECT COUNT(*) FROM employees WHERE salary > 50000; -- Filtered rows → O/P: 1

SELECT dept, COUNT(*) FROM employees GROUP BY dept; -- Count per group → O/P: IT=2, HR=2, NULL=1

SELECT name, COUNT(*) FROM employees GROUP BY name HAVING COUNT(*) > 1; -- Duplicates → O/P: (NULL,2)

RULE: COUNT(*) = all rows | COUNT(col) = non-NULLs | COUNT(DISTINCT) = unique values


