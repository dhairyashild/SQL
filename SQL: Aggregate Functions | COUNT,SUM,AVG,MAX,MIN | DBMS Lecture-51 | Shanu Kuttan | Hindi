# AVG(), MIN(), MAX() - SHORT COMMANDS

================================================================

SAMPLE TABLE: Student
+----+------+-------+----------+
| ID | Name | Marks | Dept     |
+----+------+-------+----------+
| 1  | A    | 90    | Science  |
| 2  | B    | 40    | Science  |
| 3  | C    | 70    | Commerce |
| 4  | D    | 60    | Commerce |
| 5  | E    | 70    | Arts     |
| 6  | F    | NULL  | Arts     |
+----+------+-------+----------+

================================================================

# AVG() - Average of non-NULL values
SELECT AVG(Marks) FROM Student;           -- Average all marks → O/P: 66
SELECT AVG(DISTINCT Marks) FROM Student;  -- Average unique marks → O/P: 65
SELECT Dept, AVG(Marks) FROM Student GROUP BY Dept; -- Avg per dept → O/P: Science=65, Commerce=65, Arts=70

================================================================

# MIN() - Minimum value
SELECT MIN(Marks) FROM Student;           -- Lowest mark → O/P: 40
SELECT Dept, MIN(Marks) FROM Student GROUP BY Dept; -- Min per dept → O/P: Science=40, Commerce=60, Arts=70

================================================================

# MAX() - Maximum value
SELECT MAX(Marks) FROM Student;           -- Highest mark → O/P: 90
SELECT Dept, MAX(Marks) FROM Student GROUP BY Dept; -- Max per dept → O/P: Science=90, Commerce=70, Arts=70

================================================================

# COMBINED in one query
SELECT 
    AVG(Marks) as avg_marks,
    MIN(Marks) as min_marks, 
    MAX(Marks) as max_marks 
FROM Student;  -- O/P: avg=66, min=40, max=90

RULE: All three ignore NULL values | Use GROUP BY for per-category stats
================================================================
-- WHERE example: filter rows before grouping
SELECT plant_type, SUM(downtime_minutes) AS total_downtime
FROM energy_generation
WHERE location = 'Pune'
GROUP BY plant_type;
----------------------------------->
Output:
plant_type | total_downtime
solar      | 10
hydro      | 8


-- HAVING example: filter grouped result
SELECT plant_type, SUM(downtime_minutes) AS total_downtime
FROM energy_generation
GROUP BY plant_type
HAVING SUM(downtime_minutes) > 50;
----------------------------------->
Output:
plant_type | total_downtime
solar      | 51
wind       | 77
hydro      | 41



WHERE = GROUP BY च्या आधी वापरतो
- row level filter
- एकेक रेकॉर्ड तपासतो
- उदा: location = 'Pune'

HAVING = GROUP BY च्या नंतर वापरतो
- group level filter
- SUM, COUNT, AVG सारख्या aggregate वर काम करतो
- उदा: SUM(downtime_minutes) > 500

सोपं लक्षात ठेवा:
WHERE = rows filter
HAVING = groups filter
----------------------------------------------------------------------------------

SELECT plant_type, SUM(downtime_minutes) AS total_downtime
FROM energy_generation
WHERE location = 'Pune'
GROUP BY plant_type
HAVING SUM(downtime_minutes) > 15;


What each part does:
WHERE location = 'Pune'
- Pune wali rows pehle hi choose karega.

GROUP BY plant_type
- Pune rows ko plant_type ke hisab se group karega.

HAVING SUM(downtime_minutes) > 15
- Group banne ke baad total downtime check karega.
